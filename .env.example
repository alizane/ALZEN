# ==========================================
# ALZEN V3.0 — Environment Template (DeepSeek Edition)
# Copy to .env and fill in your values.
# .env is gitignored — NEVER commit real secrets.
# ==========================================

# --- ALZEN PostgreSQL ---
ALZEN_DB_NAME=alzen_db
ALZEN_DB_USER=alzen_admin
ALZEN_DB_PASSWORD=your_secure_password
ALZEN_DB_HOST=localhost
ALZEN_DB_PORT=5432

# --- pgAdmin ---
PGADMIN_EMAIL=your_email@gmail.com
PGADMIN_PASSWORD=your_pgadmin_password

# --- LLM Providers (API Keys) ---
# DeepSeek V3 is the ONLY model used in production
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Paperclip ---
PAPERCLIP_BIND=loopback
PAPERCLIP_PORT=3100
PAPERCLIP_DB_PORT=54329

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Graphify ---
GRAPHIFY_OUTPUT_DIR=./graphify-out
GRAPHIFY_VAULT_DIR=./vault