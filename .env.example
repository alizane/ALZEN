@'
# ==========================================
# ALZEN V2.0 - ENVIRONMENT TEMPLATE
# ==========================================

# --- ALZEN PostgreSQL ---
ALZEN_DB_NAME=alzen_db
ALZEN_DB_USER=alzen_admin
ALZEN_DB_PASSWORD=
ALZEN_DB_HOST=localhost
ALZEN_DB_PORT=5432

# --- pgAdmin ---
PGADMIN_EMAIL=allauddin1524@gmail.com
PGADMIN_PASSWORD=

# --- LLM Providers (API Keys) ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# --- Paperclip ---
PAPERCLIP_BIND=loopback
PAPERCLIP_PORT=3100
PAPERCLIP_DB_PORT=54329

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Graphify ---
GRAPHIFY_OUTPUT_DIR=./graphify
GRAPHIFY_VAULT_DIR=./vault
'@ | Out-File -FilePath .env.example -Encoding utf8